# Copy this file to .env and fill in values.
# .env is gitignored — never commit it.

# Postgres
POSTGRES_DB=rico
POSTGRES_USER=rico
POSTGRES_PASSWORD=rico

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rico-raw

# Ollama
OLLAMA_MODEL=qwen2.5:3b

# Airflow
# Generate a fresh key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
# Match your local user ID (run: id -u) to avoid volume permission issues on Linux.
AIRFLOW_UID=50000

# Slack — set this; never commit the real URL to git.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
